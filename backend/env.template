# backend/.env
# ─────────────────────────────────────────────────────────────────
# Copy this file and rename it to .env
# Fill in your actual Supabase credentials below
#
# Where to find them:
#   PASSWORD    → Supabase → Settings → Database → Database password
#   PROJECT_REF → Supabase → Settings → General → Reference ID
#                 (the random string in your URL, e.g. kqscbvnucmwiakjsgmfu)
#
# ⚠ IMPORTANT: Do NOT include https:// in the host
#   CORRECT:   db.kqscbvnucmwiakjsgmfu.supabase.co
#   WRONG:     db.https://kqscbvnucmwiakjsgmfu.supabase.co
# ─────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

SECRET_KEY=django-insecure-uniliv-replace-in-production

DEBUG=True

# ─────────────────────────────────────────────────────────────────
# Your project reference is: kqscbvnucmwiakjsgmfu
# So your DATABASE_URL should look like:
#
# DATABASE_URL=postgresql://postgres:Misanalyst@123@db.kqscbvnucmwiakjsgmfu.supabase.co:5432/postgres
#
# (Replace Misanalyst@123 with your actual current password)
# ─────────────────────────────────────────────────────────────────
